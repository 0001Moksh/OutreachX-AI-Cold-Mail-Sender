# ==================== DATABASE ====================
DATABASE_URL=postgresql://user:password@localhost:5432/outreachx
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ==================== SECURITY ====================
JWT_SECRET=your-jwt-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-base64-encoded

# ==================== EMAIL SERVICE ====================
SYSTEM_EMAIL=noreply@outreachx.com
SYSTEM_EMAIL_PASSWORD=your-app-password

# Gmail SMTP
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_IMAP_SERVER=imap.gmail.com

# ==================== AI & LLM ====================
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TEMPERATURE=0.7
COHERE_API_KEY=your-cohere-api-key
COHERE_EMBED_MODEL=embed-v4.0
COHERE_OUTPUT_DIMENSION=1536

# ==================== VECTOR DB ====================
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENV=us-west1-gcp
PINECONE_INDEX=outreachx

# ==================== QUEUE & CACHE ====================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==================== STRIPE (Optional) ====================
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==================== SENDGRID (Optional) ====================
SENDGRID_API_KEY=SG.your_sendgrid_key

# ==================== GITHUB (Optional) ====================
GITHUB_TOKEN=ghp_your_github_token

# ==================== ENVIRONMENT ====================
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=True